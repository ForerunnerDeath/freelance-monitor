# ============================================================

# freelance-monitor environment example

# ============================================================

#

# Copy this file to .env and replace placeholder values:

#

# cp .env.example .env

#

# Do not commit your real .env file.

# Never put real Telegram tokens, chat IDs, cookies or Playwright

# storage_state files into Git.

# ------------------------------------------------------------

# Telegram notifications

# ------------------------------------------------------------

# Create a bot via BotFather and put the bot token here.

TELEGRAM_BOT_TOKEN=replace_with_your_telegram_bot_token

# Telegram chat/user/channel ID where notifications will be sent.

TELEGRAM_CHAT_ID=replace_with_your_telegram_chat_id

# Retry settings for Telegram sending.

MAX_TELEGRAM_RETRIES=3
TELEGRAM_RETRY_DELAY=2

# ------------------------------------------------------------

# PostgreSQL

# ------------------------------------------------------------

# These values are intended for running Python code from the host machine

# while PostgreSQL is exposed by Docker Compose on 127.0.0.1:5433.

#

# Inside Docker Compose services, the app uses the internal service name

# "postgres" and port "5432" from docker-compose.yml.

DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=freelance_monitor
DB_PASSWORD=freelance_monitor_password
DB_NAME=freelance_monitor

# ------------------------------------------------------------

# Redis

# ------------------------------------------------------------

# These values are intended for running Python code from the host machine

# while Redis is exposed by Docker Compose on 127.0.0.1:6380.

#

# Inside Docker Compose services, the app uses the internal service name

# "redis" and port "6379" from docker-compose.yml.

REDIS_HOST=127.0.0.1
REDIS_PORT=6380

# ------------------------------------------------------------

# Sources

# ------------------------------------------------------------

# FL.ru can run without manual browser authentication.

ENABLE_FL_RU=true

# Profi.ru requires manual Playwright authentication first.

# Keep it disabled by default for a clean first run.

ENABLE_PROFI_RU=false

# ------------------------------------------------------------

# Profi.ru / Playwright

# ------------------------------------------------------------

# Local development default:

# - false opens a visible browser when needed.

# - true is used inside Docker/headless environments.

PROFI_RU_HEADLESS=false

# Path to Playwright storage_state with Profi.ru cookies/localStorage.

# Generate it locally with:

#

# python -m scripts.profi_login

#

# The real file must stay ignored by Git.

PROFI_RU_STORAGE_STATE=playwright_auth/profi_storage_state.json
